# ─────────────────────────────────────────────────────────────────────────────
# pangolin_rule_updater — example.env
# ─────────────────────────────────────────────────────────────────────────────
# Two formats are supported — pick ONE.
#
# FORMAT A: Single rule (original, unchanged)
# ─────────────────────────────────────────────
# API_KEY=YOUR_LONG_BEARER_TOKEN
# RESOURCE_ID=1
# RULE_ID=1
# PANGOLIN_HOST=https://api.pangolin.example
#
# FORMAT B: Multiple rules in one container
# ──────────────────────────────────────────
# Use RULE_<N>_ prefixes. Each block is fully independent — different API
# keys, hosts, resources, rules, and modes are all supported.
# Any omitted option falls back to the corresponding global default below.

# ── Rule 1: polling mode (default) ───────────────────────────────────────────
RULE_1_API_KEY=YOUR_TOKEN_FOR_RULE_1
RULE_1_RESOURCE_ID=1
RULE_1_RULE_ID=1
RULE_1_PANGOLIN_HOST=https://api.pangolin.example
# EXPOSE_TRIGGER_WEBSITE defaults to False, so this rule polls on its own thread

# ── Rule 2: trigger / webhook mode ───────────────────────────────────────────
RULE_2_API_KEY=YOUR_TOKEN_FOR_RULE_2
RULE_2_RESOURCE_ID=2
RULE_2_RULE_ID=5
RULE_2_PANGOLIN_HOST=https://api.another-pangolin.example
# Enable trigger mode for this rule only:
RULE_2_EXPOSE_TRIGGER_WEBSITE=True
RULE_2_TRIGGER_WEBSITE_DOMAIN=trigger.rule2.dyndns.example
RULE_2_TRIGGER_WEBSITE_PATH=/update
RULE_2_TRIGGER_WEBSITE_PORT=8080            # must be unique across all trigger rules
# RULE_2_TRIGGER_SECRET=some-secret-token   # optional: require ?token=... query param

# ── Rule 3: another trigger rule on a different port ─────────────────────────
# RULE_3_API_KEY=YOUR_TOKEN_FOR_RULE_3
# RULE_3_RESOURCE_ID=3
# RULE_3_RULE_ID=7
# RULE_3_PANGOLIN_HOST=https://api.pangolin.example
# RULE_3_EXPOSE_TRIGGER_WEBSITE=True
# RULE_3_TRIGGER_WEBSITE_DOMAIN=trigger.rule3.dyndns.example
# RULE_3_TRIGGER_WEBSITE_PATH=/update
# RULE_3_TRIGGER_WEBSITE_PORT=8081          # different port from rule 2

# ─────────────────────────────────────────────────────────────────────────────
# Global defaults — apply to every rule unless overridden with RULE_N_...
# ─────────────────────────────────────────────────────────────────────────────
LOOP_SECONDS=60
LOOP_JITTER=10

IP_SERVICE_URL=https://wtfismyip.com/text,https://api.ipify.org,https://icanhazip.com

# Global trigger defaults (used if a rule sets EXPOSE_TRIGGER_WEBSITE=True
# but does not supply its own TRIGGER_WEBSITE_* values):
EXPOSE_TRIGGER_WEBSITE=False
TRIGGER_WEBSITE_DOMAIN=trigger.my.dyn.dns.com
TRIGGER_WEBSITE_PATH=/update
TRIGGER_WEBSITE_PORT=8080
# TRIGGER_SECRET=
