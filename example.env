# ─────────────────────────────────────────────────────────────────────────────
# pangolin_rule_updater — example.env
# ─────────────────────────────────────────────────────────────────────────────
# Every variable has two forms:
#
#   Global (no prefix)    — applies to all rules that don't set their own value
#   Per-rule (RULE_N_...) — overrides the global for that specific rule
#
# Required per rule: API_KEY, RESOURCE_ID, RULE_ID
# Everything else is optional and falls back to the global default.
#
# ─────────────────────────────────────────────────────────────────────────────
# FORMAT A: Single rule (original format — no prefix needed)
# ─────────────────────────────────────────────────────────────────────────────
# API_KEY=YOUR_LONG_BEARER_TOKEN
# RESOURCE_ID=1
# RULE_ID=1
# PANGOLIN_HOST=https://api.pangolin.example

# ─────────────────────────────────────────────────────────────────────────────
# FORMAT B: Multiple rules — use RULE_<N>_ prefix for each block
# ─────────────────────────────────────────────────────────────────────────────

# ── Rule 1: polling mode (inherits all globals below) ────────────────────────
RULE_1_API_KEY=YOUR_TOKEN_FOR_RULE_1
RULE_1_RESOURCE_ID=1
RULE_1_RULE_ID=1
# RULE_1_PANGOLIN_HOST=https://api.pangolin.example   # falls back to PANGOLIN_HOST
# RULE_1_TARGET_DOMAIN=                               # falls back to TARGET_DOMAIN
# RULE_1_LOOP_SECONDS=60                              # falls back to LOOP_SECONDS
# RULE_1_LOOP_JITTER=10                               # falls back to LOOP_JITTER
# RULE_1_RULE_PRIORITY=1                              # falls back to RULE_PRIORITY
# RULE_1_RULE_ACTION=ACCEPT                           # falls back to RULE_ACTION
# RULE_1_RULE_MATCH=IP                                # falls back to RULE_MATCH
# RULE_1_RULE_ENABLED=True                            # falls back to RULE_ENABLED
# RULE_1_IP_SERVICE_URL=https://api.ipify.org         # falls back to IP_SERVICE_URL
# RULE_1_EXPOSE_TRIGGER_WEBSITE=False                 # falls back to EXPOSE_TRIGGER_WEBSITE
# RULE_1_TRIGGER_WEBSITE_DOMAIN=trigger.rule1.example # falls back to TRIGGER_WEBSITE_DOMAIN
# RULE_1_TRIGGER_WEBSITE_PATH=/update                 # falls back to TRIGGER_WEBSITE_PATH
# RULE_1_TRIGGER_WEBSITE_PORT=8080                    # falls back to TRIGGER_WEBSITE_PORT
# RULE_1_TRIGGER_SECRET=                              # falls back to TRIGGER_SECRET

# ── Rule 2: trigger/webhook mode, different host, custom port ────────────────
RULE_2_API_KEY=YOUR_TOKEN_FOR_RULE_2
RULE_2_RESOURCE_ID=2
RULE_2_RULE_ID=5
RULE_2_PANGOLIN_HOST=https://api.another-pangolin.example
RULE_2_EXPOSE_TRIGGER_WEBSITE=True
RULE_2_TRIGGER_WEBSITE_DOMAIN=trigger.rule2.dyndns.example
RULE_2_TRIGGER_WEBSITE_PATH=/update
RULE_2_TRIGGER_WEBSITE_PORT=8080     # must be unique across all trigger-mode rules
# RULE_2_TRIGGER_SECRET=my-secret   # optional: require ?token=... on requests

# ── Rule 3: another trigger rule on a different port ─────────────────────────
# RULE_3_API_KEY=YOUR_TOKEN_FOR_RULE_3
# RULE_3_RESOURCE_ID=3
# RULE_3_RULE_ID=7
# RULE_3_PANGOLIN_HOST=https://api.pangolin.example
# RULE_3_EXPOSE_TRIGGER_WEBSITE=True
# RULE_3_TRIGGER_WEBSITE_DOMAIN=trigger.rule3.dyndns.example
# RULE_3_TRIGGER_WEBSITE_PATH=/update
# RULE_3_TRIGGER_WEBSITE_PORT=8081   # different port from rule 2

# ─────────────────────────────────────────────────────────────────────────────
# Global defaults — used by any rule that does not supply its own RULE_N_* value
# ─────────────────────────────────────────────────────────────────────────────
PANGOLIN_HOST=https://api.pangolin.example

TARGET_DOMAIN=                  # leave empty to use this machine's external IP

LOOP_SECONDS=60
LOOP_JITTER=10

RULE_PRIORITY=100
RULE_ACTION=ACCEPT              # ACCEPT or DROP
RULE_MATCH=IP                   # IP, CIDR, or PATH
RULE_ENABLED=True

IP_SERVICE_URL=https://wtfismyip.com/text,https://api.ipify.org,https://icanhazip.com

EXPOSE_TRIGGER_WEBSITE=False
TRIGGER_WEBSITE_DOMAIN=trigger.my.dyn.dns.com
TRIGGER_WEBSITE_PATH=/update
TRIGGER_WEBSITE_PORT=8080
# TRIGGER_SECRET=
