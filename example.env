# ─────────────────────────────────────────────────────────────────────────────
# pangolin_rule_updater — example.env
# ─────────────────────────────────────────────────────────────────────────────
# Two formats are supported — pick ONE.
#
# FORMAT A: Single rule (original, unchanged)
# ─────────────────────────────────────────────
# API_KEY=YOUR_LONG_BEARER_TOKEN
# RESOURCE_ID=1
# RULE_ID=1
# PANGOLIN_HOST=https://api.pangolin.example
#
# FORMAT B: Multiple rules in one container
# ──────────────────────────────────────────
# Use RULE_<N>_ prefixes. Each block is independent — different API keys,
# hosts, resources, and rules are all supported. Any omitted option falls
# back to the corresponding global default below.

# ── Rule 1 ────────────────────────────────────────────────────────────────────
RULE_1_API_KEY=YOUR_TOKEN_FOR_RULE_1
RULE_1_RESOURCE_ID=1
RULE_1_RULE_ID=1
RULE_1_PANGOLIN_HOST=https://api.pangolin.example

# Optional per-rule overrides (all fall back to the globals below if omitted):
# RULE_1_TARGET_DOMAIN=        # resolve this hostname instead of own IP
# RULE_1_RULE_PRIORITY=1
# RULE_1_RULE_ACTION=ACCEPT
# RULE_1_RULE_MATCH=IP
# RULE_1_RULE_ENABLED=True
# RULE_1_LOOP_SECONDS=60
# RULE_1_LOOP_JITTER=10
# RULE_1_IP_SERVICE_URL=https://wtfismyip.com/text,https://api.ipify.org

# ── Rule 2 ────────────────────────────────────────────────────────────────────
RULE_2_API_KEY=YOUR_TOKEN_FOR_RULE_2
RULE_2_RESOURCE_ID=2
RULE_2_RULE_ID=5
RULE_2_PANGOLIN_HOST=https://api.another-pangolin.example
RULE_2_TARGET_DOMAIN=my.home.dyndns.org   # track a DynDNS hostname instead of own IP

# ── Rule 3 ────────────────────────────────────────────────────────────────────
# RULE_3_API_KEY=...
# RULE_3_RESOURCE_ID=3
# RULE_3_RULE_ID=7
# RULE_3_PANGOLIN_HOST=https://api.pangolin.example

# ─────────────────────────────────────────────────────────────────────────────
# Global defaults — apply to every rule unless overridden with RULE_N_...
# ─────────────────────────────────────────────────────────────────────────────
LOOP_SECONDS=60
LOOP_JITTER=10

IP_SERVICE_URL=https://wtfismyip.com/text,https://api.ipify.org,https://icanhazip.com

# ── Webhook / trigger mode (optional, applies globally) ───────────────────────
# When enabled, automatic polling is disabled and all rules are updated
# together whenever the trigger endpoint receives a request.
EXPOSE_TRIGGER_WEBSITE=False
TRIGGER_WEBSITE_DOMAIN=trigger.my.dyn.dns.com
TRIGGER_WEBSITE_PATH=/update
TRIGGER_WEBSITE_PORT=8080
# TRIGGER_SECRET=some-secret-token   # optional: require ?token=... query param
